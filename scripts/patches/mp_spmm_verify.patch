+int valueToStorage(int value) {
+    switch (value) {
+        case 0: return 0b00;
+        case 1: return 0b01;
+        case 2: return 0b10;
+        case 3: return 0b11;
+        default: return 0; 
+    }
+}
+
+void storeArrayInUint32(int *metadata_old, uint32_t *metadata_new, int block_row, int block_col, int block_start) {
+ 
+  int start_row = (block_start+block_col) * tile_M * tile_K / 2;
+  //printf("%d ,%d ,%d \n",block_start,block_col,block_count_each_window);
+   for (int r = 0; r < 16 / 2; ++r) { 
+       for (int c = 0; c < 8 / 2; ++c) {  
+           int value_lower0 = metadata_old[start_row + r *  tile_K/2  + c * 2];
+           int value_lower1 = metadata_old[start_row + r *  tile_K/2 + c * 2 + 1];   
+           int value_upper0 = metadata_old[start_row + (r+8) * tile_K/2 + c * 2];
+           int value_upper1 = metadata_old[start_row + (r+8) *  tile_K/2 + c * 2 + 1]; 
+          //  int value_lower0 = metadata_old[(r) * tile_K/2  + c * 2];
+          //  int value_lower1 = metadata_old[(r) * tile_K/2  + c * 2 + 1];   
+          //  int value_upper0 = metadata_old[(r+8) * tile_K/2  + c * 2];
+          //  int value_upper1 = metadata_old[(r+8) * tile_K/2  + c * 2 + 1]; 
+           int storageValue_lower0 = valueToStorage(value_lower0);
+           int storageValue_lower1 = valueToStorage(value_lower1);    
+           int storageValue_upper0 = valueToStorage(value_upper0); 
+           int storageValue_upper1 = valueToStorage(value_upper1); 
+
+           int bit_pos_lower0 = c * 4;
+           int bit_pos_lower1 = c * 4 + 2;   
+           int bit_pos_upper0 = c * 4 + 16;
+           int bit_pos_upper1 = c * 4 + 16 + 2; 
+           int idx =  r + (block_start + block_col) * 8;
+           //printf("%d ",idx);
+           metadata_new[idx] |= (storageValue_lower0 << bit_pos_lower0);
+           metadata_new[idx] |= (storageValue_lower1 << bit_pos_lower1);  
+           metadata_new[idx] |= (storageValue_upper0 << bit_pos_upper0);
+           metadata_new[idx] |= (storageValue_upper1 << bit_pos_upper1);   
+       }
+   }
+}
+
+void storeArrayInUint32ForLargeMatrix(int *metadata_old, uint32_t *metadata_new, std::vector<int> tcblocks_offset) {
+  for(int block_row = 0;block_row < tcblocks_offset.size()-1;block_row++){
+    int block_start = tcblocks_offset[block_row];
+    int block_end = tcblocks_offset[block_row + 1];
+    int block_count_each_window = tcblocks_offset[block_row + 1] - tcblocks_offset[block_row];
+      for (int block_col = 0; block_col < block_count_each_window; ++block_col) {  
+          storeArrayInUint32(metadata_old, metadata_new, block_row, block_col, block_start);
+  }
+  }  
+}
+
+void sparse_dense_multiply(
+  std::vector<int> A_rows,
+  std::vector<int> A_cols,
+  std::vector<half> A_values,
+  half* B,    
+  int B_cols,          
+  float *C          
+) {
+
+  for (size_t i = 0; i < A_values.size(); ++i) {
+      const int row = A_rows[i];
+      const int col = A_cols[i];
+      const half val = A_values[i];
+
+      const int B_offset = col * B_cols;
+      const int C_offset = row * B_cols; 
+      
+      for (int k = 0; k < B_cols; ++k) {     
+          C[C_offset + k] = static_cast<float>(C[C_offset + k]) +
+          __half2float(val) * __half2float(B[B_offset + k]);
+      }
+  }
+}
+
+void compare_cpu_gpu(float *CPU, float *GPU, size_t size)
+{
+  for (size_t i = 0; i < size; i++)
+  {
+    if (CPU[i] != GPU[i]){
+       printf("error: CPU: %f, GPU: %f\n", CPU[i], GPU[i]);
+    }else{
+       printf("correct: CPU: %f, GPU: %f\n", CPU[i], GPU[i]);
+    }
+  }
+}
+
+// check results
+void all_close(float* array1, float* array2, size_t length, std::vector<size_t> &different_indices, float rtol=1e-3, float atol=1e-3) {  
+    float tolerance;  
+  
+    for (size_t i = 0; i < length; i++) {  
+        tolerance = atol + rtol * std::fabs(array2[i]);  
+        if (std::fabs(array1[i] - array2[i]) > tolerance) {  
+            different_indices.push_back(i); 
+        }  
+    } 
+
+    if (different_indices.size() == 0){
+        std::cout << "Results Check Passed !!! " << std::endl;  
+    } else {
+        std::cout << "Number of different elements: " << different_indices.size() << std::endl;  
+ 
+        size_t max_to_print = std::min(different_indices.size(), size_t(10));  
+        for (size_t i = 0; i < max_to_print; i++) {  
+            std::cout << "Index: " << different_indices[i] << ", Value: " << array1[different_indices[i]] << ' ' << array2[different_indices[i]]<< std::endl;  
+        } 
+        std::cout << std::endl; 
+    }  
+}
